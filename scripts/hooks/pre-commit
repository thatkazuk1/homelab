#!/bin/bash
# Regenerate handbook stack pages when compose files or notes change.

set -e

CHANGED_STACKS=$(git diff --cached --name-only | grep -E '^stacks/[^/]+/(compose(\.[^/]+)?\.yml|notes\.md)$' || true)

if [ -n "$CHANGED_STACKS" ]; then
    echo "Detected stack changes, regenerating handbook stack pages..."
    python3 scripts/generate-stack-pages.py
    git add handbook/docs/stacks/ handbook/mkdocs.yml
    echo "Regenerated pages (including any prunes) and nav added to commit."
fi

# Dimension A: ADR reference validity (hard-fail). Runs against the local working
# tree, not the git-staged/tracked tree — docs/adrs/ is disk-only (ADR-0012) and
# never committed, so this check only works here, not in CI. See
# docs/adr-audit-2026-07-21.md for why CI enforcement of this dimension was dropped.
if ! python3 scripts/check-adr-references.py; then
    echo "ERROR: ADR reference validation failed. Fix references or commit is blocked."
    exit 1
fi
